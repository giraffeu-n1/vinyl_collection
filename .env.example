# Скопируйте в .env для локальной разработки или задайте в панели Timeweb App Platform

DJANGO_SECRET_KEY=замените-на-длинную-случайную-строку
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=ваш-домен.ru,www.ваш-домен.ru
# Опционально: один URL сайта (добавится в CSRF)
# DJANGO_SITE_URL=https://ваш-домен.ru
DJANGO_CSRF_TRUSTED_ORIGINS=https://ваш-домен.ru,https://www.ваш-домен.ru
